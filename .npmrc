shamefully-hoist=true

# GitHub Packages registry for the @cuweb scope.
# Locally: add //npm.pkg.github.com/:_authToken=<PAT> to ~/.npmrc
# In CI: set NODE_AUTH_TOKEN in the workflow env (see .github/workflows/ci.yml)
@cuweb:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}