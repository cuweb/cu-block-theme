{
	"packageManager": "pnpm@10.33.2",
	"prettier": "@wordpress/prettier-config",
	"scripts": {
		"clean": "rm -rf assets/css assets/js",
		"build:css": "sass src/styles.scss:assets/css/styles.css src/editor.scss:assets/css/editor.css --style=compressed --no-source-map",
		"build:blocks": "sass src/css/blocks:assets/css/blocks --style=compressed --no-source-map",
		"build:js": "esbuild src/script.js --bundle --minify --outfile=assets/js/script.js",
		"build": "pnpm run clean && run-p build:css build:blocks build:js",
		"start:css": "sass src/styles.scss:assets/css/styles.css src/editor.scss:assets/css/editor.css --watch",
		"start:blocks": "sass src/css/blocks:assets/css/blocks --watch",
		"start:js": "esbuild src/script.js --bundle --watch --sourcemap --outfile=assets/js/script.js",
		"start": "run-p start:css start:blocks start:js",
		"lint:js": "eslint .",
		"lint:css": "stylelint \"src/**/*.{scss,css}\"",
		"lint:php": "composer lint && composer phpstan",
		"lint": "run-s lint:js lint:css lint:php",
		"format": "prettier --write . && composer format",
		"format:php": "composer format",
		"format:check": "prettier --check .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,mjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{scss,css}": [
			"stylelint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml,html}": "prettier --write",
		"*.php": [
			"vendor/bin/phpcbf",
			"vendor/bin/phpcs"
		]
	},
	"devDependencies": {
		"@wordpress/eslint-plugin": "^25.0.0",
		"@wordpress/prettier-config": "^4.44.0",
		"@wordpress/stylelint-config": "^23.36.0",
		"esbuild": "^0.27.4",
		"eslint": "^10.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.3",
		"sass": "^1.83.0",
		"stylelint": "^16.26.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		]
	}
}
