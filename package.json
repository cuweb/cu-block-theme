{
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "clean": "rm -rf assets/css assets/js",
    "build:css": "sass src/styles.scss:assets/css/styles.css src/editor.scss:assets/css/editor.css --style=compressed --no-source-map",
    "build:blocks": "sass src/css/blocks:assets/css/blocks --style=compressed --no-source-map",
    "build:js": "esbuild src/script.js --bundle --minify --outfile=assets/js/script.js",
    "build": "pnpm run clean && run-p build:css build:blocks build:js",
    "start:css": "sass src/styles.scss:assets/css/styles.css src/editor.scss:assets/css/editor.css --watch",
    "start:blocks": "sass src/css/blocks:assets/css/blocks --watch",
    "start:js": "esbuild src/script.js --bundle --watch --sourcemap --outfile=assets/js/script.js",
    "start": "run-p start:css start:blocks start:js"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "npm-run-all": "^4.1.5",
    "sass": "^1.83.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
